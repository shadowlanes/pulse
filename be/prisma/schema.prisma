generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pulse {
  id        String   @id @default(cuid())
  date      DateTime @unique
  status    String   // "Good" or "Bad"
  score     Float    @default(5.0)
  headlines Json     // Array of headlines
  rationale String   @db.Text
  sp500     Float?   // S&P 500 index value (SPY ETF close)
  gold      Float?   // Gold price (GLD ETF close)
  qqq       Float?   // Nasdaq-100 index (QQQ ETF close)
  bitcoin   Float?   // Bitcoin price (BTC-USD close)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pulse")
}
